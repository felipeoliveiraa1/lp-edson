---
import Layout from '../layouts/Layout.astro';

const variants = [
  { id: 'V1', name: 'Spotlight P (atual, refinada)' },
  { id: 'V2', name: 'Monograma PZ — selo circular' },
  { id: 'V3', name: 'Zero-Palco (o "0" vira holofote)' },
  { id: 'V4', name: 'Feixe de holofote' },
  { id: 'V5', name: 'Wordmark minimalista' },
  { id: 'V6', name: 'PZ geométrico (diamante)' },
];
---

<Layout title="Logos — Palco Zero">
  <main class="wrap">
    <header class="head">
      <h1>Versões de logo — Palco Zero</h1>
      <p>Escolha a que mais gostou (pode misturar ideias). Cada cartão mostra a logo no fundo escuro e a marca isolada.</p>
    </header>

    <div class="grid">
      {variants.map((v) => (
        <section class="card">
          <span class="tag">{v.id} · {v.name}</span>
          <div class="stage">
            <div class={`logo logo-${v.id}`}>
              {/* ============ V1 ============ */}
              {v.id === 'V1' && (
                <>
                  <span class="mark">
                    <svg viewBox="0 0 40 40" fill="none">
                      <defs><linearGradient id="g1" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#7c3aed"/><stop offset="1" stop-color="#b06bff"/></linearGradient></defs>
                      <rect x="1" y="1" width="38" height="38" rx="11" stroke="url(#g1)" stroke-width="1.6"/>
                      <path d="M13 29V12h7a5 5 0 0 1 0 10h-3v7z" fill="url(#g1)"/>
                      <circle cx="27" cy="14" r="2.4" fill="#ffd9a8"/>
                    </svg>
                  </span>
                  <span class="wm"><strong>PALCO</strong><em>ZERO</em></span>
                </>
              )}

              {/* ============ V2 ============ */}
              {v.id === 'V2' && (
                <>
                  <span class="mark">
                    <svg viewBox="0 0 44 44" fill="none">
                      <defs><linearGradient id="g2" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#6d28d9"/><stop offset="1" stop-color="#b06bff"/></linearGradient></defs>
                      <circle cx="22" cy="22" r="21" fill="url(#g2)"/>
                      <circle cx="22" cy="22" r="21" stroke="#c4b5ff" stroke-opacity="0.4"/>
                      <text x="22" y="29" text-anchor="middle" font-family="Sora,sans-serif" font-weight="800" font-size="19" fill="#fff" letter-spacing="-1">PZ</text>
                    </svg>
                  </span>
                  <span class="wm wm-stack"><strong>PALCO ZERO</strong><small>IMERSÃO PRESENCIAL</small></span>
                </>
              )}

              {/* ============ V3 ============ */}
              {v.id === 'V3' && (
                <span class="wm wm-big">
                  PALCO ZER<span class="zero">
                    <svg viewBox="0 0 40 40" fill="none">
                      <defs><linearGradient id="g3" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#b06bff"/><stop offset="1" stop-color="#7c3aed"/></linearGradient></defs>
                      <circle cx="20" cy="20" r="15" stroke="url(#g3)" stroke-width="4.5"/>
                      <circle cx="20" cy="7" r="3" fill="#ffd9a8"/>
                    </svg>
                  </span>
                </span>
              )}

              {/* ============ V4 ============ */}
              {v.id === 'V4' && (
                <>
                  <span class="mark">
                    <svg viewBox="0 0 44 44" fill="none">
                      <defs>
                        <linearGradient id="g4" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#b06bff" stop-opacity="0.9"/><stop offset="1" stop-color="#7c3aed" stop-opacity="0.15"/></linearGradient>
                      </defs>
                      <circle cx="22" cy="9" r="4" fill="#ffd9a8"/>
                      <path d="M22 12 L36 38 H8 Z" fill="url(#g4)"/>
                      <ellipse cx="22" cy="38" rx="11" ry="2.4" fill="#b06bff" opacity="0.55"/>
                    </svg>
                  </span>
                  <span class="wm"><strong>PALCO</strong><em>ZERO</em></span>
                </>
              )}

              {/* ============ V5 ============ */}
              {v.id === 'V5' && (
                <span class="wm wm-min">
                  <span class="palco">PALCO</span><span class="zero-grad">ZERO</span><span class="dot"></span>
                </span>
              )}

              {/* ============ V6 ============ */}
              {v.id === 'V6' && (
                <>
                  <span class="mark">
                    <svg viewBox="0 0 44 44" fill="none">
                      <defs><linearGradient id="g6" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#7c3aed"/><stop offset="1" stop-color="#b06bff"/></linearGradient></defs>
                      <rect x="22" y="2" width="28" height="28" rx="7" transform="rotate(45 22 2)" stroke="url(#g6)" stroke-width="1.6"/>
                      <text x="22" y="28" text-anchor="middle" font-family="Sora,sans-serif" font-weight="800" font-size="16" fill="url(#g6)" letter-spacing="-1">PZ</text>
                    </svg>
                  </span>
                  <span class="wm"><strong>PALCO</strong><em>ZERO</em></span>
                </>
              )}
            </div>
          </div>
        </section>
      ))}
    </div>
  </main>
</Layout>

<style>
  .wrap { max-width: 1100px; margin-inline: auto; padding: 7rem 1.5rem 5rem; }
  .head h1 { font-family: var(--font-display); font-size: 2rem; font-weight: 800; }
  .head p { margin-top: 0.6rem; color: color-mix(in srgb, #fff 65%, transparent); max-width: 60ch; }
  .grid { margin-top: 3rem; display: grid; grid-template-columns: 1fr; gap: 1.2rem; }
  @media (min-width: 720px) { .grid { grid-template-columns: 1fr 1fr; } }

  .card {
    border-radius: 1.2rem;
    border: 1px solid color-mix(in srgb, var(--color-violet-400) 16%, transparent);
    background: color-mix(in srgb, var(--color-night-800) 50%, transparent);
    overflow: hidden;
  }
  .tag {
    display: block;
    padding: 0.9rem 1.2rem;
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-violet-300);
    border-bottom: 1px solid color-mix(in srgb, var(--color-violet-400) 12%, transparent);
  }
  .stage {
    min-height: 150px;
    display: grid;
    place-items: center;
    padding: 2rem;
    background:
      radial-gradient(70% 80% at 30% 20%, color-mix(in srgb, var(--color-violet-700) 28%, transparent), transparent 70%),
      linear-gradient(160deg, var(--color-night-900), var(--color-night-950));
  }

  /* lockup base */
  .logo { display: inline-flex; align-items: center; gap: 0.7rem; }
  .mark { width: 2.6rem; height: 2.6rem; display: grid; place-items: center; filter: drop-shadow(0 4px 14px rgba(151,71,255,.45)); }
  .mark svg { width: 100%; height: 100%; }

  .wm { font-family: var(--font-display); font-weight: 700; font-size: 1.25rem; letter-spacing: 0.14em; line-height: 1; display: inline-flex; gap: 0.3rem; color: #fff; }
  .wm strong { font-weight: 800; }
  .wm em { font-style: normal; font-weight: 600; color: var(--color-violet-300); }

  .wm-stack { flex-direction: column; gap: 0.3rem; align-items: flex-start; letter-spacing: 0.1em; }
  .wm-stack small { font-size: 0.55rem; letter-spacing: 0.32em; color: color-mix(in srgb,#fff 55%,transparent); font-weight: 600; }

  /* V3 */
  .wm-big { font-size: 1.7rem; letter-spacing: 0.08em; align-items: center; display: inline-flex; }
  .wm-big .zero { display: inline-block; width: 1.5rem; height: 1.5rem; margin-left: 0.1rem; vertical-align: middle; }
  .wm-big .zero svg { width: 100%; height: 100%; filter: drop-shadow(0 0 10px rgba(176,107,255,.6)); }

  /* V5 */
  .wm-min { align-items: center; letter-spacing: 0.18em; }
  .wm-min .palco { font-weight: 500; color: color-mix(in srgb,#fff 80%,transparent); }
  .wm-min .zero-grad { font-weight: 800; background: linear-gradient(100deg,#c2a8ff,#7c3aed); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .wm-min .dot { width: 7px; height: 7px; border-radius: 999px; background: #ffd9a8; box-shadow: 0 0 10px 2px #ffd9a8; margin-left: 2px; }
</style>
