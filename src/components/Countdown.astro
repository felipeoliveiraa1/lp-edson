---
import { site } from '../data/site';
interface Props { compact?: boolean }
const { compact = false } = Astro.props;
---

<div class:list={['countdown', { 'countdown--compact': compact }]} data-countdown data-target={site.eventDateISO} aria-live="polite">
  <div class="cd-unit">
    <span class="cd-num" data-days>00</span>
    <span class="cd-label">dias</span>
  </div>
  <span class="cd-sep">:</span>
  <div class="cd-unit">
    <span class="cd-num" data-hours>00</span>
    <span class="cd-label">horas</span>
  </div>
  <span class="cd-sep">:</span>
  <div class="cd-unit">
    <span class="cd-num" data-minutes>00</span>
    <span class="cd-label">min</span>
  </div>
  <span class="cd-sep">:</span>
  <div class="cd-unit">
    <span class="cd-num" data-seconds>00</span>
    <span class="cd-label">seg</span>
  </div>
</div>

<style>
  .countdown {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .cd-unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 4.1rem;
    padding: 0.7rem 0.5rem 0.55rem;
    border-radius: 1rem;
    background: linear-gradient(
      160deg,
      color-mix(in srgb, var(--color-night-700) 60%, transparent),
      color-mix(in srgb, var(--color-night-900) 80%, transparent)
    );
    border: 1px solid color-mix(in srgb, var(--color-violet-400) 22%, transparent);
    box-shadow: 0 18px 40px -24px rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(10px);
  }
  .cd-num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.5rem, 4vw, 2.05rem);
    line-height: 1;
    font-variant-numeric: tabular-nums;
    background: linear-gradient(180deg, #fff, var(--color-violet-300));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .cd-label {
    margin-top: 0.35rem;
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in srgb, #fff 60%, transparent);
  }
  .cd-sep {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.4rem;
    color: var(--color-glow-400);
    opacity: 0.6;
    align-self: flex-start;
    margin-top: 0.85rem;
  }
  @media (max-width: 460px) {
    .countdown:not(.countdown--compact) { gap: 0.35rem; width: 100%; }
    .countdown:not(.countdown--compact) .cd-unit { min-width: 0; flex: 1; padding: 0.6rem 0.2rem 0.5rem; }
    .countdown:not(.countdown--compact) .cd-sep { display: none; }
    .countdown:not(.countdown--compact) .cd-num { font-size: clamp(1.15rem, 6.5vw, 1.7rem); }
  }

  /* ===== Variante compacta (barra do topo) — cards menores ===== */
  .countdown--compact { gap: 0.35rem; }
  .countdown--compact .cd-unit {
    min-width: 2.7rem;
    padding: 0.25rem 0.35rem 0.2rem;
    border-radius: 0.55rem;
    background: color-mix(in srgb, #000 22%, transparent);
    border: 1px solid color-mix(in srgb, #fff 22%, transparent);
    box-shadow: 0 4px 12px -8px rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(6px);
  }
  .countdown--compact .cd-num {
    font-size: 1.05rem;
    background: linear-gradient(180deg, #fff, var(--color-violet-300));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .countdown--compact .cd-label {
    margin-top: 0.05rem;
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    color: color-mix(in srgb, #fff 72%, transparent);
  }
  .countdown--compact .cd-sep { display: none; }
</style>

<script>
  function startCountdown(el: HTMLElement) {
    const target = new Date(el.dataset.target as string).getTime();
    const d = el.querySelector('[data-days]')!;
    const h = el.querySelector('[data-hours]')!;
    const m = el.querySelector('[data-minutes]')!;
    const s = el.querySelector('[data-seconds]')!;
    const pad = (n: number) => String(Math.max(0, n)).padStart(2, '0');

    const tick = () => {
      const diff = target - Date.now();
      if (diff <= 0) {
        d.textContent = h.textContent = m.textContent = s.textContent = '00';
        clearInterval(timer);
        return;
      }
      const sec = Math.floor(diff / 1000);
      d.textContent = pad(Math.floor(sec / 86400));
      h.textContent = pad(Math.floor((sec % 86400) / 3600));
      m.textContent = pad(Math.floor((sec % 3600) / 60));
      s.textContent = pad(sec % 60);
    };
    tick();
    const timer = setInterval(tick, 1000);
  }
  document.querySelectorAll<HTMLElement>('[data-countdown]').forEach(startCountdown);
</script>
