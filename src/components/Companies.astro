---
// Marcas / autoridades de empresas que já aplicaram o método.
const segmentos = ['Indústria', 'Varejo', 'Tecnologia', 'Saúde', 'Educação', 'Serviços Financeiros'];
---

<section id="marcas" class="section companies">
  <div class="container-x">
    <div class="companies-head" data-reveal>
      <span class="kicker">Autoridades & empresas</span>
      <h2 class="companies-title">
        Marcas que já aplicaram o método
        <span class="text-gradient">Voz de Autoridade</span>
      </h2>
      <p class="companies-lead">
        A percepção estratégica e o método comportamental revelados na imersão
        já foram aplicados em líderes e equipes de grandes empresas.
      </p>
    </div>

    <div class="marcas-card" data-reveal>
      <img
        src="/img/marcas.webp"
        alt="Logos de empresas que já aplicaram o método: Itaú, Bosch, Coca-Cola, LATAM, McDonald's, Mercedes-Benz, P&G, entre outras"
        loading="lazy"
        decoding="async"
      />
    </div>

    <div class="segmentos" data-reveal>
      {segmentos.map((c) => <span class="segmento">{c}</span>)}
    </div>
  </div>
</section>

<style>
  .companies { padding-top: clamp(1.5rem, 3vw, 2.5rem); }
  .companies-head { text-align: center; max-width: 760px; margin-inline: auto; }
  .companies-title {
    margin-top: 1.1rem;
    font-size: clamp(1.6rem, 3.8vw, 2.4rem);
    font-weight: 800;
  }
  .companies-lead {
    margin-top: 1.1rem;
    color: color-mix(in srgb, #fff 68%, transparent);
  }

  .marcas-card {
    margin-top: 2.8rem;
  }
  .marcas-card img {
    display: block;
    width: 100%;
    max-width: 980px;
    margin-inline: auto;
    height: auto;
  }

  .segmentos {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.7rem;
  }
  .segmento {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    color: color-mix(in srgb, #fff 70%, transparent);
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-violet-400) 18%, transparent);
    background: color-mix(in srgb, var(--color-night-800) 50%, transparent);
  }
</style>
