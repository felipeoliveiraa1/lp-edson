---
import SceneBg from './SceneBg.astro';
const stats = [
  { value: '+1.000', label: 'projetos exclusivos realizados por Issao Imamura' },
  { value: '+300', label: 'empresas impactadas pela metodologia' },
  { value: '+1 milhão', label: 'de pessoas alcançadas com as técnicas' },
  { value: '3 min', label: 'é o tempo que você tem para prender a plateia' },
];

// Recortes de imprensa (validação de mercado).
// Para adicionar a 3ª: salve o webp em public/img e inclua aqui um objeto novo.
const noticias = [
  {
    img: '/img/noticia-folha.webp',
    fonte: 'Folha de S.Paulo',
    titulo: 'Mercado de palestras dispara, e empresário planeja cobrar R$ 1 milhão em 2026',
  },
  {
    img: '/img/noticia-valor.webp',
    fonte: 'Valor Econômico',
    titulo: 'Cresce a demanda por palestras motivacionais: mercado global pode chegar a US$ 2,9 bi até 2027',
  },
  {
    img: '/img/noticia-exame.webp',
    fonte: 'Exame · Negócios em Expansão 2025',
    titulo: '7º lugar no ranking entre 750 empresas: R$ 30 milhões de faturamento e +30 mil alunos formados',
  },
];
---

<section id="metodo" class="section market">
  <SceneBg src="/img/scenes/purple_stage.webp" position="center" opacity={0.3} />
  <div class="blob" style="background: var(--color-violet-700); width: 420px; height: 420px; top: -60px; right: -80px;"></div>

  <div class="container-x">
    <div class="market-head" data-reveal>
      <span class="kicker">O contexto</span>
      <h2 class="market-title">
        O mercado de comunicação corporativa
        <span class="text-gradient">está explodindo</span>
      </h2>
      <p class="market-lead">
        A pergunta é simples: você vai se preparar para falar em público com a
        autoridade que merece, ou vai continuar deixando oportunidades para
        quem já aprendeu?
      </p>
    </div>

    <div class="stats-grid">
      {stats.map((s, i) => (
        <div class="stat glass" data-reveal data-reveal-delay={(i % 4) + 1}>
          <span class="stat-value text-gradient">{s.value}</span>
          <span class="stat-label">{s.label}</span>
        </div>
      ))}
    </div>

    <div class="news-block" data-reveal>
      <span class="news-eyebrow">Na imprensa</span>
      <div class="news-carousel" aria-label="Recortes de imprensa">
        <div class="news-track">
          {[...noticias, ...noticias].map((n, i) => (
            <figure class="news-card" aria-hidden={i >= noticias.length ? 'true' : undefined}>
              <img src={n.img} alt={`${n.fonte}: ${n.titulo}`} loading="lazy" decoding="async" />
            </figure>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .market { padding-top: clamp(3.5rem, 7vw, 6rem); isolation: isolate; }
  .market .container-x { position: relative; z-index: 2; }
  .market-head { max-width: 720px; }
  .market-title {
    margin-top: 1.1rem;
    font-size: clamp(1.9rem, 4.6vw, 3rem);
    font-weight: 800;
  }
  .market-lead {
    margin-top: 1.3rem;
    font-size: clamp(1.05rem, 2.2vw, 1.25rem);
    color: color-mix(in srgb, #fff 72%, transparent);
    max-width: 58ch;
  }
  .stats-grid {
    margin-top: 3.2rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .stat {
    padding: 1.8rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: transform 0.4s var(--ease-smooth), border-color 0.4s var(--ease-smooth);
  }
  .stat:hover {
    transform: translateY(-6px);
    border-color: color-mix(in srgb, var(--color-violet-400) 40%, transparent);
  }
  .stat-value {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.9rem, 4vw, 2.6rem);
    line-height: 1;
  }
  .stat-label {
    font-size: 0.95rem;
    color: color-mix(in srgb, #fff 66%, transparent);
  }
  @media (min-width: 880px) {
    .stats-grid { grid-template-columns: repeat(4, 1fr); }
  }

  /* Recortes de imprensa */
  .news-block { margin-top: clamp(2.6rem, 5vw, 3.6rem); }
  .news-eyebrow {
    display: block;
    text-align: center;
    font-family: var(--font-display);
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-violet-300);
    margin-bottom: 1.4rem;
  }
  .news-carousel {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent);
  }
  .news-track {
    display: flex;
    gap: 1.1rem;
    width: max-content;
    animation: news-scroll 36s linear infinite;
  }
  .news-carousel:hover .news-track { animation-play-state: paused; }
  @keyframes news-scroll {
    to { transform: translateX(-50%); }
  }
  .news-card {
    width: clamp(300px, 86vw, 470px);
    height: clamp(330px, 52vh, 430px);
    flex-shrink: 0;
    display: grid;
    place-items: center;
    padding: 0.7rem;
    background: #fff;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-violet-400) 16%, transparent);
    box-shadow: 0 30px 60px -42px rgba(0, 0, 0, 0.85);
  }
  .news-card img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    border-radius: 0.45rem;
  }
  @media (prefers-reduced-motion: reduce) {
    .news-track { animation: none; flex-wrap: wrap; justify-content: center; width: 100%; }
  }
</style>
