---
import Logo from './Logo.astro';
import { navLinks } from '../data/site';
---

<footer class="footer">
  <div class="hairline"></div>
  <div class="container-x footer-inner">
    <div class="footer-brand">
      <Logo />
      <p>O único encontro presencial onde você sai com a palestra gravada no mesmo dia.</p>
    </div>

    <nav class="footer-nav" aria-label="Rodapé">
      {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
  </div>

  <div class="container-x footer-bottom">
    <span>© {new Date().getFullYear()} Palco Zero · Edson Lins & Issao Imamura. Todos os direitos reservados.</span>
    <span class="footer-legal">Este conteúdo não garante resultados. Resultados variam conforme a dedicação de cada participante.</span>
  </div>
</footer>

<style>
  .footer { padding-top: 3rem; padding-bottom: 2.5rem; }
  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    padding-top: 3rem;
  }
  .footer-brand p {
    margin-top: 1rem;
    max-width: 38ch;
    color: color-mix(in srgb, #fff 58%, transparent);
    font-size: 0.95rem;
  }
  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.3rem;
    align-content: start;
  }
  .footer-nav a {
    color: color-mix(in srgb, #fff 70%, transparent);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.25s;
  }
  .footer-nav a:hover { color: var(--color-violet-300); }
  .footer-bottom {
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: 0.82rem;
    color: color-mix(in srgb, #fff 45%, transparent);
  }
  @media (min-width: 760px) {
    .footer-inner { grid-template-columns: 1.4fr 1fr; }
    .footer-nav { justify-content: flex-end; }
  }
</style>
