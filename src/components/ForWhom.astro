---
import { site } from '../data/site';

const forYou = [
  'Quer sair do evento com uma palestra gravada e pronta para usar',
  'É CEO, diretor, empresário ou líder que quer falar com autoridade',
  'Já tentou falar em público, travou, e quer entender de onde vem o bloqueio',
  'Quer ser reconhecido como referência no seu mercado',
  'Quer usar o palco como ferramenta de posicionamento e geração de negócios',
  'Tem o desejo de contribuir com o mundo através do seu conhecimento e entregar a sua mensagem',
  'Está disposto a investir 1 dia para transformar sua comunicação para sempre',
];
const notForYou = [
  'Quer fórmula mágica sem se dedicar ao processo',
  'Não está disposto a subir no palco durante a imersão',
  'Acha que comunicação não é uma habilidade que precisa ser desenvolvida',
  'Acha que já sabe falar tudo e não precisa melhorar a sua fala no palco',
  'Não acredita que seja possível transformar a sua fala em 1 dia',
];
---

<section id="para-quem" class="section forwhom">
  <div class="container-x">
    <div class="forwhom-head" data-reveal>
      <span class="kicker">Para quem é</span>
      <h2 class="forwhom-title">
        A Imersão <span class="text-gradient">Palco Zero</span> é para você?
      </h2>
    </div>

    <div class="forwhom-grid">
      <div class="fw-card fw-yes glass" data-reveal data-reveal-delay="1">
        <h3 class="fw-card-title">
          <span class="fw-badge fw-badge-yes">✓</span> Para quem é
        </h3>
        <ul class="fw-list">
          {forYou.map((t) => (
            <li>
              <svg class="fw-icon yes" width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{t}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="fw-card fw-no glass" data-reveal data-reveal-delay="2">
        <h3 class="fw-card-title">
          <span class="fw-badge fw-badge-no">✕</span> Para quem NÃO é
        </h3>
        <ul class="fw-list">
          {notForYou.map((t) => (
            <li>
              <svg class="fw-icon no" width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
              </svg>
              <span>{t}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="forwhom-cta" data-reveal>
      <a href={site.ctaHref} class="btn btn-primary">{site.ctaLabel}</a>
    </div>
  </div>
</section>

<style>
  .forwhom-head { text-align: center; max-width: 640px; margin-inline: auto; }
  .forwhom-title {
    margin-top: 1.1rem;
    font-size: clamp(1.8rem, 4.4vw, 2.85rem);
    font-weight: 800;
  }
  .forwhom-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
  }
  .fw-card { padding: 2.2rem 2rem; }
  .fw-yes { border-color: color-mix(in srgb, var(--color-violet-400) 30%, transparent); }
  .fw-no { border-color: color-mix(in srgb, #ff6b8a 18%, transparent); }
  .fw-card-title {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-size: 1.3rem;
    font-weight: 700;
  }
  .fw-badge {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    font-size: 1rem;
  }
  .fw-badge-yes {
    background: linear-gradient(150deg, var(--color-violet-600), var(--color-glow-500));
    color: #fff;
  }
  .fw-badge-no {
    background: color-mix(in srgb, #ff6b8a 22%, transparent);
    color: #ff9fb2;
  }
  .fw-list {
    list-style: none;
    margin: 1.6rem 0 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }
  .fw-list li {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
    color: color-mix(in srgb, #fff 80%, transparent);
    font-size: 1rem;
  }
  .fw-icon { flex-shrink: 0; margin-top: 2px; }
  .fw-icon.yes { color: var(--color-glow-400); }
  .fw-icon.no { color: #ff8aa3; }
  .forwhom-cta { margin-top: 2.6rem; text-align: center; }
  @media (min-width: 860px) {
    .forwhom-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
