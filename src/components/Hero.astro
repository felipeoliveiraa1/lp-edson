---
import Countdown from './Countdown.astro';
import { site } from '../data/site';
---

<section id="topo" class="hero">
  <!-- Background image -->
  <div class="hero-bg" aria-hidden="true">
    <img src="/img/new-hero.webp" alt="" fetchpriority="high" decoding="async" />
  </div>
  <!-- Gradient veils for legibility + depth -->
  <div class="hero-veil" aria-hidden="true"></div>
  <div class="hero-glow" aria-hidden="true"></div>

  <div class="container-x hero-inner">
    <div class="hero-content" data-reveal>
      <span class="kicker">{site.tagline} · vagas limitadas</span>

      <p class="hero-pretitle" data-reveal data-reveal-delay="1">
        O único encontro presencial onde você sai com a palestra
        <span class="text-glow">gravada no mesmo dia</span>
      </p>

      <h1 class="hero-title" data-reveal data-reveal-delay="2">
        Em <span class="text-gradient">1 dia</span> você conhece a estrutura
        exata para sair com sua primeira palestra
        <span class="text-gradient">gravada, destravada</span> e reconhecida
        pelo mercado.
      </h1>

      <p class="hero-sub" data-reveal data-reveal-delay="3">
        <strong>Edson Lins</strong> e <strong>Issao Imamura</strong>, o maior
        ilusionista do Brasil, revelam o método que destrava líderes,
        empresários e diretores — e os coloca no palco com presença e
        autoridade real.
      </p>

      <div class="hero-actions" data-reveal data-reveal-delay="4">
        <a href={site.ctaHref} class="btn btn-primary pulse-ring">
          {site.ctaLabel}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <div class="hero-meta">
          <span>{site.eventDateLabel}</span>
          <span class="dot">•</span>
          <span>{site.eventCity}</span>
        </div>
      </div>

      <div class="hero-countdown" data-reveal data-reveal-delay="5">
        <span class="hero-countdown-label">A imersão começa em</span>
        <Countdown />
      </div>
    </div>
  </div>

  <a href="#metodo" class="scroll-cue" aria-label="Rolar para baixo">
    <span></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: clamp(7rem, 14vh, 10rem);
    padding-bottom: clamp(4rem, 9vh, 7rem);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 65% center;
    animation: hero-zoom 18s ease-out forwards;
  }
  @keyframes hero-zoom {
    from { transform: scale(1.08); }
    to { transform: scale(1); }
  }
  /* Veil: dark on the left for text legibility, transparent on the right (subject) */
  .hero-veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      /* tinta diagonal: roxo + azul-marinho à esquerda, some à direita */
      linear-gradient(
        105deg,
        color-mix(in srgb, var(--color-night-800) 78%, var(--color-violet-700)) 0%,
        color-mix(in srgb, var(--color-night-900) 70%, transparent) 26%,
        color-mix(in srgb, var(--color-night-900) 28%, transparent) 50%,
        transparent 76%
      ),
      /* base em azul-marinho com leve roxo */
      linear-gradient(
        to top,
        color-mix(in srgb, var(--color-night-900) 90%, var(--color-violet-700)) 0%,
        transparent 42%
      ),
      /* brilho roxo no canto inferior esquerdo */
      radial-gradient(
        62% 72% at 10% 72%,
        color-mix(in srgb, var(--color-violet-700) 42%, transparent),
        transparent 70%
      );
  }
  .hero-glow {
    position: absolute;
    z-index: 1;
    left: -10%;
    top: 30%;
    width: 50vw;
    height: 50vw;
    max-width: 620px;
    max-height: 620px;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-glow-500) 38%, transparent), transparent 65%);
    filter: blur(40px);
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    width: 100%;
  }
  .hero-content {
    max-width: 620px;
    text-shadow: 0 2px 30px rgba(4, 5, 15, 0.7), 0 1px 3px rgba(4, 5, 15, 0.5);
  }
  /* destaques: gradiente roxo -> claro, com brilho roxo (sem sombra escura) */
  .hero-title .text-gradient {
    background: linear-gradient(100deg, #a877ff 0%, #d8c4ff 55%, #f4eeff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 0 28px rgba(150, 110, 255, 0.5);
  }
  .hero-pretitle .text-glow {
    color: #e7dbff;
    text-shadow: 0 0 22px rgba(160, 120, 255, 0.5);
  }
  .hero-pretitle {
    margin-top: 1.3rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(0.88rem, 1.8vw, 1.05rem);
    color: color-mix(in srgb, #fff 82%, transparent);
    line-height: 1.4;
    max-width: 36ch;
  }
  .hero-title {
    margin-top: 0.85rem;
    font-size: clamp(1.5rem, 3.3vw, 2.35rem);
    font-weight: 800;
    line-height: 1.12;
  }
  .hero-sub {
    margin-top: 1.3rem;
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    color: color-mix(in srgb, #fff 74%, transparent);
    max-width: 50ch;
  }
  .hero-sub strong {
    color: #fff;
    font-weight: 600;
  }
  .hero-actions {
    margin-top: 2.2rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.3rem;
  }
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.92rem;
    color: color-mix(in srgb, #fff 72%, transparent);
    font-weight: 500;
  }
  .hero-meta .dot { color: var(--color-glow-400); }
  .hero-countdown {
    margin-top: 2.6rem;
  }
  .hero-countdown-label {
    display: block;
    margin-bottom: 0.7rem;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-violet-300) 90%, transparent);
  }

  .scroll-cue {
    position: absolute;
    z-index: 3;
    bottom: 1.6rem;
    left: 50%;
    transform: translateX(-50%);
    width: 26px;
    height: 42px;
    border: 2px solid color-mix(in srgb, #fff 35%, transparent);
    border-radius: 999px;
    display: grid;
    place-items: start center;
    padding-top: 7px;
  }
  .scroll-cue span {
    width: 4px;
    height: 8px;
    border-radius: 999px;
    background: #fff;
    animation: scroll-cue 1.8s var(--ease-smooth) infinite;
  }
  @keyframes scroll-cue {
    0% { opacity: 0; transform: translateY(0); }
    40% { opacity: 1; }
    80% { opacity: 0; transform: translateY(12px); }
    100% { opacity: 0; }
  }
  @media (max-width: 600px) {
    .hero {
      align-items: flex-end;
      padding-top: 6rem;
      padding-bottom: clamp(2.5rem, 7vh, 4rem);
    }
    .hero-bg img { object-position: 62% 12%; }
    /* Reforça o escurecimento na base pra o conteúdo descer e ficar legível */
    .hero-veil {
      background:
        linear-gradient(
          to top,
          var(--color-night-950) 18%,
          color-mix(in srgb, var(--color-night-950) 70%, transparent) 48%,
          transparent 82%
        );
    }
    .hero-content { margin-top: auto; }
    .scroll-cue { display: none; }
  }
</style>
