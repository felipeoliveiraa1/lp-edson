---
const mentors = [
  {
    name: 'Edson Lins',
    role: 'Mentor Comportamental',
    photo: '/img/edson.webp' as string | null,
    bio: 'Treinador comportamental, empresário e especialista em mentalidade, identidade, inteligência emocional e desenvolvimento humano. Sua trajetória foi construída na prática: ergueu negócios do zero, atravessou crises e processos de reconstrução que moldaram quem ele é.',
    mission: 'Sua missão é clara: formar líderes conscientes, posicionados e responsáveis, que sabem quem são antes de abrir a boca.',
    tags: ['Mentalidade', 'Identidade', 'Inteligência emocional'],
  },
  {
    name: 'Issao Imamura',
    role: 'Ilusionista Estratégico',
    photo: '/img/issao.webp' as string | null,
    bio: 'Primeiro e maior ilusionista da história do Brasil. Criador do ilusionismo estratégico, hoje reconhecido como mestre em percepção estratégica. Já realizou mais de 1.000 projetos exclusivos para mais de 300 empresas, impactando mais de 1 milhão de pessoas.',
    mission: 'Aplica o estudo de como as pessoas percebem, acreditam e decidem para treinar líderes a se comunicar com clareza, impacto e autoridade.',
    tags: ['Percepção estratégica', '+300 empresas', '+1M de pessoas'],
  },
];
---

<section id="mentores" class="section mentors">
  <div class="blob" style="background: var(--color-violet-700); width: 460px; height: 460px; top: 12%; right: -160px; opacity: 0.3;"></div>

  <div class="container-x">
    <div class="mentors-head" data-reveal>
      <span class="kicker">Quem conduz</span>
      <h2 class="mentors-title">
        Quem estará por trás da sua
        <span class="text-gradient">jornada na imersão</span>
      </h2>
      <p class="mentors-lead">
        Dois universos que se encontram em um único dia: o comportamento humano e
        a percepção estratégica — lado a lado, focados na sua transformação.
      </p>
    </div>

    <div class="mentors-list">
      {mentors.map((m, i) => (
        <article class={`mentor-row ${i % 2 === 1 ? 'is-reversed' : ''}`} data-reveal>
          <!-- Foto / painel -->
          <div class="mentor-figure">
            {m.photo ? (
              <div class="figure-photo">
                <img src={m.photo} alt={`Foto de ${m.name}`} loading="lazy" decoding="async" />
                <span class="figure-tag">{m.role}</span>
              </div>
            ) : (
              <div class="figure-placeholder">
                <span class="figure-initials">{m.name.split(' ').map((n) => n[0]).join('')}</span>
                <span class="figure-tag figure-tag-static">{m.role}</span>
              </div>
            )}
          </div>

          <!-- Texto -->
          <div class="mentor-info">
            <span class="mentor-role">{m.role}</span>
            <h3 class="mentor-name">{m.name}</h3>
            <p class="mentor-bio">{m.bio}</p>
            <p class="mentor-mission">{m.mission}</p>
            <div class="mentor-tags">
              {m.tags.map((t) => <span class="mentor-tag">{t}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .mentors { isolation: isolate; }
  .mentors .container-x { position: relative; z-index: 2; }
  .mentors-head { max-width: 720px; }
  .mentors-title {
    margin-top: 1.1rem;
    font-size: clamp(1.8rem, 4.4vw, 2.85rem);
    font-weight: 800;
  }
  .mentors-lead {
    margin-top: 1.2rem;
    color: color-mix(in srgb, #fff 70%, transparent);
    max-width: 60ch;
  }

  .mentors-list {
    margin-top: 3.4rem;
    display: grid;
    gap: clamp(2.5rem, 6vw, 4.5rem);
  }
  .mentor-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }

  /* Figura */
  .mentor-figure { position: relative; }
  .figure-photo,
  .figure-placeholder {
    position: relative;
    border-radius: 1.6rem;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    border: 1px solid color-mix(in srgb, var(--color-violet-400) 20%, transparent);
    box-shadow: 0 40px 80px -40px rgba(0, 0, 0, 0.8);
  }
  .figure-photo::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, color-mix(in srgb, var(--color-night-950) 85%, transparent) 4%, transparent 45%),
      radial-gradient(70% 50% at 20% 15%, color-mix(in srgb, var(--color-violet-700) 35%, transparent), transparent 70%);
    mix-blend-mode: screen;
  }
  .figure-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.8s var(--ease-smooth);
  }
  .mentor-row:hover .figure-photo img { transform: scale(1.04); }

  .figure-placeholder {
    display: grid;
    place-items: center;
    background:
      radial-gradient(80% 60% at 50% 25%, color-mix(in srgb, var(--color-violet-600) 35%, transparent), transparent 70%),
      linear-gradient(160deg, var(--color-night-700), var(--color-night-900));
  }
  .figure-initials {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(3.5rem, 12vw, 6rem);
    background: linear-gradient(180deg, #fff, var(--color-violet-300));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .figure-tag {
    position: absolute;
    left: 1.2rem;
    bottom: 1.2rem;
    z-index: 2;
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    color: #fff;
    background: color-mix(in srgb, var(--color-night-900) 70%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-violet-400) 30%, transparent);
    backdrop-filter: blur(8px);
  }
  .figure-tag-static {
    position: static;
    margin-top: 1.2rem;
    display: inline-block;
  }
  .figure-placeholder { flex-direction: column; }

  /* Texto */
  .mentor-role {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-violet-300);
  }
  .mentor-name {
    margin-top: 0.6rem;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 800;
  }
  .mentor-bio {
    margin-top: 1.3rem;
    color: color-mix(in srgb, #fff 74%, transparent);
    font-size: 1.02rem;
  }
  .mentor-mission {
    margin-top: 1.1rem;
    color: color-mix(in srgb, #fff 90%, transparent);
    font-weight: 500;
    border-left: 2px solid var(--color-glow-500);
    padding-left: 1.1rem;
  }
  .mentor-tags {
    margin-top: 1.6rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .mentor-tag {
    font-size: 0.82rem;
    font-weight: 500;
    padding: 0.45rem 0.95rem;
    border-radius: 999px;
    color: var(--color-violet-300);
    background: color-mix(in srgb, var(--color-violet-600) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-violet-400) 22%, transparent);
  }

  /* Mobile: foto em cima, texto embaixo, foto em tamanho proporcional */
  @media (max-width: 859px) {
    .mentor-row {
      grid-template-columns: 1fr;
    }
    .mentor-figure {
      order: 0;
      width: 100%;
      max-width: 340px;
      margin-inline: auto;
    }
    .mentor-info { order: 1; }
    .figure-photo,
    .figure-placeholder { aspect-ratio: 4 / 4.2; }
  }

  @media (min-width: 860px) {
    .mentor-row {
      grid-template-columns: 0.85fr 1.15fr;
      gap: clamp(2.5rem, 5vw, 4rem);
    }
    .mentor-row.is-reversed { grid-template-columns: 1.15fr 0.85fr; }
    .mentor-row.is-reversed .mentor-figure { order: 2; }
    .mentor-row.is-reversed .mentor-info { order: 1; }
  }
</style>
