---
import Countdown from './Countdown.astro';
import { site } from '../data/site';
---

<div class="cdbar">
  <div class="container-x cdbar-inner">
    <span class="cdbar-label">
      <span class="cdbar-dot" aria-hidden="true"></span>
      A imersão começa em
    </span>
    <Countdown compact light />
    <a href={site.ctaHref} class="cdbar-cta">{site.ctaLabel}</a>
  </div>
</div>

<style>
  .cdbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 60;
    height: var(--bar-h);
    display: flex;
    align-items: center;
    background: linear-gradient(100deg, var(--color-gold-300), var(--color-gold-400) 50%, var(--color-gold-500));
    border-bottom: 1px solid color-mix(in srgb, #2c1f06 22%, transparent);
    box-shadow: 0 6px 20px -12px rgba(0, 0, 0, 0.55);
  }
  .cdbar-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
  }
  .cdbar-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #2c1f06;
    white-space: nowrap;
  }
  .cdbar-dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--color-violet-700);
    box-shadow: 0 0 8px 1px color-mix(in srgb, var(--color-violet-600) 70%, transparent);
    animation: cdbar-pulse 1.8s ease-in-out infinite;
  }
  @keyframes cdbar-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }
  .cdbar-cta {
    flex-shrink: 0;
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    padding: 0.45rem 1.1rem;
    border-radius: 999px;
    background: var(--color-violet-700);
    border: 1px solid color-mix(in srgb, #2c1f06 20%, transparent);
    box-shadow: 0 4px 12px -6px rgba(0, 0, 0, 0.5);
    transition: background 0.25s, transform 0.25s var(--ease-smooth);
    white-space: nowrap;
  }
  .cdbar-cta:hover {
    background: var(--color-violet-600);
    transform: translateY(-1px);
  }

  /* Mobile: barra mais enxuta */
  @media (max-width: 600px) {
    .cdbar-inner { gap: 0.6rem; justify-content: space-between; }
    .cdbar-label { font-size: 0.68rem; }
    .cdbar-label .cdbar-dot { display: none; }
    .cdbar-cta { display: none; }
  }
  @media (max-width: 380px) {
    .cdbar-label { display: none; }
    .cdbar-inner { justify-content: center; }
  }
</style>
