---
import { site } from '../data/site';
import SceneBg from './SceneBg.astro';
// Prova social — placeholders prontos para receber depoimentos reais (vídeo/print).
const testimonials = [
  {
    quote: 'Saí da imersão com a minha palestra gravada e a clareza de quem finalmente sabe o que tem a dizer no palco.',
    name: 'Participante',
    role: 'CEO · Indústria',
  },
  {
    quote: 'O ilusionismo estratégico do Issao desbloqueou algo que nenhum curso de oratória tinha conseguido em anos.',
    name: 'Participante',
    role: 'Diretora · Varejo',
  },
  {
    quote: 'Em 1 dia entendi de onde vinha o meu medo de falar e subi no palco com uma presença que eu não conhecia.',
    name: 'Participante',
    role: 'Empresário · Tecnologia',
  },
];
---

<section class="section proof">
  <SceneBg src="/img/scenes/conf_audience.webp" position="center" opacity={0.26} />
  <div class="container-x">
    <div class="proof-head" data-reveal>
      <span class="kicker">Prova social</span>
      <h2 class="proof-title">
        Melhor do que falar...
        <span class="text-gradient">é mostrar na prática</span>
      </h2>
    </div>

    <div class="proof-grid">
      {testimonials.map((t, i) => (
        <figure class="testimonial glass" data-reveal data-reveal-delay={(i % 3) + 1}>
          <div class="quote-mark" aria-hidden="true">"</div>
          <blockquote>{t.quote}</blockquote>
          <figcaption>
            <span class="t-name">{t.name}</span>
            <span class="t-role">{t.role}</span>
          </figcaption>
        </figure>
      ))}
    </div>

    <div class="proof-cta" data-reveal>
      <a href={site.ctaHref} class="btn btn-gold">
        Quero me tornar um palestrante de autoridade
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .proof { isolation: isolate; }
  .proof .container-x { position: relative; z-index: 2; }
  .proof-head { text-align: center; max-width: 640px; margin-inline: auto; }
  .proof-title {
    margin-top: 1.1rem;
    font-size: clamp(1.8rem, 4.4vw, 2.85rem);
    font-weight: 800;
  }
  .proof-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
  }
  .testimonial {
    padding: 2.2rem 1.9rem;
    position: relative;
    transition: transform 0.4s var(--ease-smooth);
    background: #ffffff;
    border: 1px solid color-mix(in srgb, var(--color-violet-400) 18%, transparent);
  }
  .testimonial:hover { transform: translateY(-6px); }
  .quote-mark {
    font-family: var(--font-display);
    font-size: 3.5rem;
    line-height: 0.7;
    color: var(--color-violet-500);
    opacity: 0.55;
  }
  blockquote {
    margin: 1rem 0 0;
    font-size: 1.05rem;
    color: color-mix(in srgb, var(--color-night-900) 86%, transparent);
    line-height: 1.55;
  }
  figcaption {
    margin-top: 1.6rem;
    display: flex;
    flex-direction: column;
  }
  .t-name { font-weight: 700; color: var(--color-night-900); }
  .t-role { font-size: 0.88rem; color: var(--color-violet-700); }
  .proof-cta { margin-top: 2.8rem; text-align: center; }
  @media (min-width: 860px) {
    .proof-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
